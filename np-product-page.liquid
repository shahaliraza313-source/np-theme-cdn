{% comment %}np-product-page.liquid{% endcomment %}
{% assign cv = product.selected_or_first_available_variant %}
{% assign cp = section.settings.c_primary %}
{% assign cg = section.settings.c_gold %}
{% assign cbg = section.settings.c_bg %}
{% assign ct = section.settings.c_text %}
{% if section.settings.font_head == 'serif' %}{% assign fh = "Georgia,'Times New Roman',serif" %}{% else %}{% assign fh = "'Helvetica Neue',Arial,sans-serif" %}{% endif %}
{% if section.settings.font_body == 'serif' %}{% assign fb = "Georgia,'Times New Roman',serif" %}{% else %}{% assign fb = "'Helvetica Neue',Arial,sans-serif" %}{% endif %}
{{ 'np-product.css' | asset_url | stylesheet_tag }}
<style>.np-wrap{--np-fb:{{ fb }};--np-fh:{{ fh }};--np-ct:{{ ct }};--np-cbg:{{ cbg }};--np-cp:{{ cp }};--np-cg:{{ cg }};--np-fs-logo:{{ section.settings.fs_logo }}px;--np-c-logo:{{ section.settings.c_logo }};--np-fs-logo-sub:{{ section.settings.fs_logo_sub }}px;--np-fs-label:{{ section.settings.fs_label }}px;--np-fs-title:{{ section.settings.fs_title }}px;--np-c-title:{{ section.settings.c_title }};--np-c-muted:{{ section.settings.c_muted }};--np-fs-price:{{ section.settings.fs_price }}px;--np-c-price:{{ section.settings.c_price }};--np-c-compare:{{ section.settings.c_compare }};--np-fs-atc:{{ section.settings.fs_atc }}px;--np-c-atc-bg:{{ section.settings.c_atc_bg }};--np-c-atc-text:{{ section.settings.c_atc_text }};--np-c-trust-label:{{ section.settings.c_trust_label }};--np-fs-acc-head:{{ section.settings.fs_acc_head }}px;--np-c-acc-head:{{ section.settings.c_acc_head }};--np-fs-body:{{ section.settings.fs_body }}px;--np-c-body:{{ section.settings.c_body }}}</style>
<div class="np-wrap" data-variants="{{ product.variants | json | escape }}" data-money="{{ shop.money_format | escape }}">
{% form 'product', product %}
<div class="np-product">
  <div class="np-gallery">
    <img id="np-main-img" class="np-main-img" src="{{ product.featured_image | img_url: '800x' }}" alt="{{ product.title | escape }}">
    <div class="np-thumbs">{% for img in product.images %}<img class="np-thumb {% if forloop.first %}active{% endif %}" src="{{ img | img_url: '160x' }}" alt="{{ img.alt | escape }}" onclick="npImg(this,'{{ img | img_url: '800x' }}')">{% endfor %}</div>
  </div>
  <div class="np-info">
    <div class="np-brand-label">{{ section.settings.brand_label }}</div>
    <h1 class="np-title">{{ product.title }}</h1>
    <div class="np-subtitle">{{ section.settings.subtitle }}</div>
    <div class="np-price-row" id="np-price-row">
      <span class="np-price-now" id="np-price">{{ cv.price | money }}</span>
      {% if cv.compare_at_price > cv.price %}<span class="np-price-was" id="np-compare">{{ cv.compare_at_price | money }}</span>{% endif %}
    </div>
    <div class="np-rating-row">
      <span class="np-stars">{% assign s = section.settings.stars %}{% for i in (1..5) %}{% if i <= s %}★{% else %}☆{% endif %}{% endfor %}</span>
      <span class="np-rating-link">{{ section.settings.founded_text }}</span>
    </div>
    <input type="hidden" name="id" id="np-vid" value="{{ cv.id }}">
    {% for opt in product.options_with_values %}{% assign oi = forloop.index0 %}
      {% if opt.name == 'Color' or opt.name == 'Colour' %}
        <div class="np-opt-label">COLOR: <span id="np-col-val">{{ opt.values.first }}</span></div>
        <div class="np-color-swatches" data-oi="{{ oi }}">{% for val in opt.values %}{% assign sw_img = product.images[forloop.index0] | default: product.featured_image %}
          <div class="np-swatch {% if forloop.first %}active{% endif %}" data-val="{{ val }}" title="{{ val }}" onclick="npColor(this,{{ oi }})"><img src="{{ sw_img | img_url: '80x' }}" alt="{{ val }}"></div>
        {% endfor %}</div>
      {% else %}
        <div class="np-size-label-row">
          <div class="np-opt-label">{{ opt.name | upcase }}: <span id="np-sv-{{ oi }}">{{ opt.values.first }}</span></div>
          {% if opt.name == 'Size' %}<span class="np-size-chart">&#8594; Size Chart</span>{% endif %}
        </div>
        <div class="np-sizes" data-oi="{{ oi }}">{% for val in opt.values %}<button type="button" class="np-size-btn {% if forloop.first %}active{% endif %}" data-val="{{ val }}" onclick="npSize(this,{{ oi }})">{{ val }}</button>{% endfor %}</div>
      {% endif %}
    {% endfor %}
    <button type="submit" name="add" class="np-atc">ADD TO CART &nbsp;&#8594;</button>
    {% for block in section.blocks %}{% if block.type == 'payment_badges' %}
    <div class="np-payments" {{ block.shopify_attributes }}>{% if block.settings.pay_img_1 %}<img class="np-pay-badge" src="{{ block.settings.pay_img_1 | img_url: '120x' }}" alt="">{% endif %}{% if block.settings.pay_img_2 %}<img class="np-pay-badge" src="{{ block.settings.pay_img_2 | img_url: '120x' }}" alt="">{% endif %}{% if block.settings.pay_img_3 %}<img class="np-pay-badge" src="{{ block.settings.pay_img_3 | img_url: '120x' }}" alt="">{% endif %}{% unless block.settings.pay_img_1 or block.settings.pay_img_2 or block.settings.pay_img_3 %}<span class="np-pay-icon">PayPal</span><span class="np-pay-icon">VISA</span><span class="np-pay-icon">Apple Pay</span><span class="np-pay-icon">MC</span><span class="np-pay-icon">AMEX</span><span class="np-pay-icon">Shop Pay</span>{% endunless %}</div>
    {% endif %}{% endfor %}
    {% for block in section.blocks %}{% if block.type == 'scarcity' %}<div class="np-scarcity" {{ block.shopify_attributes }}>{{ block.settings.text }}</div>{% endif %}{% endfor %}
    {% for block in section.blocks %}{% if block.type == 'trust_rows' %}
    <div class="np-trust-rows" {{ block.shopify_attributes }}>
      <div class="np-trust-row"><div class="np-trust-icon">&#128666;</div><div><span class="np-trust-label">{{ block.settings.tr1_label }}</span><span class="np-trust-sub">{{ block.settings.tr1_sub }}</span></div></div>
      <div class="np-trust-row"><div class="np-trust-icon">&#128205;</div><div><span class="np-trust-label">{{ block.settings.tr2_label }}</span><span class="np-trust-sub">{{ block.settings.tr2_sub }}</span></div></div>
      <div class="np-trust-row"><div class="np-trust-icon">&#127991;</div><div><span class="np-trust-label">{{ block.settings.tr3_label }}</span><span class="np-trust-sub">{{ block.settings.tr3_sub }}</span></div></div>
      <div class="np-trust-row"><div class="np-trust-icon">&#127873;</div><div><span class="np-trust-label">{{ block.settings.tr4_label }}</span><span class="np-trust-sub">{{ block.settings.tr4_sub }}</span></div></div>
    </div>
    {% endif %}{% endfor %}
    {% for block in section.blocks %}{% if block.type == 'alert' %}<div class="np-alert" {{ block.shopify_attributes }}><span class="np-alert-title">{{ block.settings.title }}</span><p>{{ block.settings.text }}</p></div>{% endif %}{% endfor %}
    {% assign has_acc = false %}{% for block in section.blocks %}{% if block.type == 'accordion_item' %}{% assign has_acc = true %}{% endif %}{% endfor %}
    {% if has_acc %}<div class="np-accordion">{% for block in section.blocks %}{% if block.type == 'accordion_item' %}
    <div class="np-acc-item" {{ block.shopify_attributes }}><div class="np-acc-head" onclick="npAcc(this)">{{ block.settings.heading }} <span class="np-acc-arrow">+</span></div><div class="np-acc-body">{% if block.settings.content_type == 'description' %}{{ product.description }}{% else %}<p>{{ block.settings.content | newline_to_br }}</p>{% endif %}</div></div>
    {% endif %}{% endfor %}</div>{% endif %}
  </div>
</div>
{% endform %}
</div>
<div class="np-sticky" id="np-sticky">
  <img class="np-sticky-thumb" src="{{ product.featured_image | img_url: '100x' }}" alt="">
  <div class="np-sticky-info"><div class="np-sticky-name">{{ product.title | upcase | truncate: 28 }}</div><div class="np-sticky-price" id="np-sprice">{{ cv.price | money }}</div></div>
  <div class="np-sticky-selects">{% for opt in product.options_with_values %}<select class="np-sticky-sel" onchange="npSticky(this,{{ forloop.index0 }})">{% for val in opt.values %}<option value="{{ val }}">{{ val }}</option>{% endfor %}</select>{% endfor %}</div>
  <button class="np-sticky-atc" onclick="document.querySelector('button[name=add]').click()">ADD TO CART &#8594;</button>
</div>
<script src="{{ 'np-product.js' | asset_url }}" defer></script>
{% schema %}
{"name":"NP Product Page","settings":[{"type":"text","id":"brand_label","label":"Brand label","default":"THE ROSEMARY LANE"},{"type":"text","id":"subtitle","label":"Subtitle","default":"Selected pieces from Rosemary's final collection."},{"type":"range","id":"stars","label":"Stars","min":0,"max":5,"step":1,"default":5},{"type":"text","id":"founded_text","label":"Rating text","default":"Founded in 2008 in London"},{"type":"color","id":"c_primary","label":"Primary","default":"#7B1A1A"},{"type":"color","id":"c_gold","label":"Gold accent","default":"#C9A84C"},{"type":"color","id":"c_bg","label":"Background","default":"#faf7f2"},{"type":"color","id":"c_text","label":"Body text","default":"#1a1a1a"},{"type":"select","id":"font_head","label":"Heading font","options":[{"value":"serif","label":"Serif"},{"value":"sans","label":"Sans-serif"}],"default":"serif"},{"type":"select","id":"font_body","label":"Body font","options":[{"value":"sans","label":"Sans-serif"},{"value":"serif","label":"Serif"}],"default":"sans"},{"type":"range","id":"fs_logo","label":"Logo size","min":14,"max":48,"step":1,"unit":"px","default":24},{"type":"range","id":"fs_logo_sub","label":"Tagline size","min":7,"max":16,"step":1,"unit":"px","default":9},{"type":"range","id":"fs_title","label":"Title size","min":14,"max":48,"step":1,"unit":"px","default":22},{"type":"range","id":"fs_price","label":"Price size","min":14,"max":48,"step":1,"unit":"px","default":22},{"type":"range","id":"fs_label","label":"Label size","min":8,"max":18,"step":1,"unit":"px","default":12},{"type":"range","id":"fs_atc","label":"ATC size","min":10,"max":22,"step":1,"unit":"px","default":14},{"type":"range","id":"fs_acc_head","label":"Acc head size","min":10,"max":20,"step":1,"unit":"px","default":13},{"type":"range","id":"fs_body","label":"Body size","min":10,"max":20,"step":1,"unit":"px","default":13},{"type":"color","id":"c_logo","label":"Logo colour","default":"#1a1a1a"},{"type":"color","id":"c_title","label":"Title colour","default":"#1a1a1a"},{"type":"color","id":"c_price","label":"Price colour","default":"#1a1a1a"},{"type":"color","id":"c_compare","label":"Compare price","default":"#aaaaaa"},{"type":"color","id":"c_muted","label":"Muted text","default":"#888888"},{"type":"color","id":"c_trust_label","label":"Trust label","default":"#1a1a1a"},{"type":"color","id":"c_acc_head","label":"Acc head colour","default":"#1a1a1a"},{"type":"color","id":"c_body","label":"Body colour","default":"#444444"},{"type":"color","id":"c_atc_bg","label":"ATC background","default":"#7B1A1A"},{"type":"color","id":"c_atc_text","label":"ATC text","default":"#ffffff"}],"blocks":[{"type":"payment_badges","name":"Payment Badges","limit":1,"settings":[{"type":"image_picker","id":"pay_img_1","label":"Badge 1"},{"type":"image_picker","id":"pay_img_2","label":"Badge 2"},{"type":"image_picker","id":"pay_img_3","label":"Badge 3"}]},{"type":"scarcity","name":"Scarcity Text","limit":1,"settings":[{"type":"text","id":"text","label":"Text","default":"Only a few items left"}]},{"type":"trust_rows","name":"Trust Rows","limit":1,"settings":[{"type":"text","id":"tr1_label","label":"Row 1 title","default":"FREE SHIPPING"},{"type":"text","id":"tr1_sub","label":"Row 1 subtitle","default":"Within the United Kingdom"},{"type":"text","id":"tr2_label","label":"Row 2 title","default":"30-DAY GUARANTEE"},{"type":"text","id":"tr2_sub","label":"Row 2 subtitle","default":"Try it risk-free"},{"type":"text","id":"tr3_label","label":"Row 3 title","default":"STRICTLY LIMITED"},{"type":"text","id":"tr3_sub","label":"Row 3 subtitle","default":"Handmade, limited quantities"},{"type":"text","id":"tr4_label","label":"Row 4 title","default":"EVERY 10TH ORDER IS FREE"},{"type":"text","id":"tr4_sub","label":"Row 4 subtitle","default":"As a thank you"}]},{"type":"alert","name":"Alert Box","limit":1,"settings":[{"type":"text","id":"title","label":"Alert title","default":"RETIREMENT SALE UPDATE:"},{"type":"textarea","id":"text","label":"Alert text","default":"Due to high demand, only a few items remain in stock."}]},{"type":"accordion_item","name":"Accordion Tab","settings":[{"type":"text","id":"heading","label":"Heading","default":"Product Details"},{"type":"select","id":"content_type","label":"Content","options":[{"value":"description","label":"Product description"},{"value":"custom","label":"Custom text"}],"default":"description"},{"type":"textarea","id":"content","label":"Custom text","default":""}]}],"presets":[{"name":"NP Product Page"}]}
{% endschema %}
